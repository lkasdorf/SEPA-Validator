{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SEPA Validator",
  "version": "2.1.0",
  "identifier": "dev.sepa.validator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SEPA XML Validator",
        "width": 1100,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/lkasdorf/SEPA-Validator/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZEMENENkUyNjA5OTM1OTUKUldTVk5abGc0dFlNL2NxaDJhNHg1NXlNWnhSemExOGpXL1F2OE9xL0xQOHlzK1RwZDErbDdkZlkK"
    }
  }
}
